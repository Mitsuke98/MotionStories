PORT=4000
DATABASE_URL=postgres://user:password@host:5432/motion_story
JWT_SECRET=replace_with_random_64_char_hex
KEY_ENCRYPTION_SECRET=replace_with_random_64_char_hex
CORS_ORIGIN=https://your-vercel-app.vercel.app

# Object storage (Cloudflare R2 or AWS S3)
S3_ENDPOINT=https://accountid.r2.cloudflarestorage.com
S3_BUCKET=motion-story-frames
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

MAX_FRAMES_PER_VIDEO=20
# ffmpeg/yt-dlp are installed via nixpacks on Railway — leave blank
